{
  "name": "zenon-client",
  "version": "1.0.5",
  "description": "Zenon Client - A modern Minecraft launcher",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/zyros14/zenon-client.git"
  },
  "scripts": {
    "postinstall": "node scripts/reapply-prismarine-live-patch.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "adm-zip": "^0.5.12",
    "bcryptjs": "^3.0.3",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.2.0",
    "minecraft-launcher-core": "^3.7.1",
    "node-fetch": "^2.7.0",
    "prismarine-auth": "^2.5.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "^26.8.1"
  },
  "author": "Zenon Client",
  "license": "MIT",
  "build": {
    "appId": "com.zenon.client",
    "productName": "Zenon Client",
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "scripts/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/zenon-logo.png",
      "artifactName": "Zenon-Client-Setup-${version}.${ext}"
    },
    "nsis": {
      "shortcutName": "Zenon Client",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "zyros14",
        "repo": "zenon-client"
      }
    ]
  }
}
